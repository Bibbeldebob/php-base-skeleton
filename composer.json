{
    "name": "bibbeldebob/php-skeleton",
    "description": "A PHP Skeleton with devcontainer for easy and quick start of new projects",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests"
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "unit": "vendor/bin/phpunit",
        "stan": "vendor/bin/phpstan analyse -c phpstan.neon -vv"
    }
}
